<?xml version="1.0" encoding="utf-8"?>
<!--
    Minimal input view for the droid-mcp keyboard. Typing is driven by MCP
    tools, so there are no keys — but a tappable "Switch back" button keeps
    users from getting stuck after picking the keyboard.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="?android:attr/colorBackground">

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/droid_mcp_ime_label"
        android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary" />

    <Button
        android:id="@+id/droid_mcp_ime_switch_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/droid_mcp_ime_switch_back" />
</LinearLayout>
